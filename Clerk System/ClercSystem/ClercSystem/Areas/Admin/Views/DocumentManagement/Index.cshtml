    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
} *@

@if (TempData["Message"] != null)
{
    <div class="alert alert-danger temp-alert">
        @TempData["Message"]
    </div>
}


<h2>Documents</h2> 
