<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th scope="col">Name</th>
            <th scope="col">Creator</th>
            <th scope="col">Category</th>
            <th scope="col">Department</th>
            <th scope="col" class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (AllDocumentsAdminViewModel doc in Model)
        {
            <tr>
                <td>@doc.Title</td>
                <td>@doc.Createdby</td>
                <td>@doc.CategoryName</td>
                <td>@doc.DepartmentName</td>
                <td class="text-center">
                    <a asp-area="Document" asp-controller="Document" asp-route-source="admin" asp-action="More" asp-route-id="@doc.Id" class="btn btn-info btn-sm me-2">
                        <i class="bi bi-calendar-plus"></i> More
                    </a>

                    @if (User.IsInRole("Admin") || User.IsInRole("User"))
                    {
                        <a asp-area="Document" asp-controller="Document" asp-route-source="admin" asp-action="Edit" asp-route-id="@doc.Id"  class="btn btn-info btn-sm me-2">
                            <i class="bi bi-calendar-plus"></i> Edit
                        </a>

                        @if(!doc.IsDeleted)
                        {
                            if(User.IsInRole("Admin"))
                            {
                                <form asp-route-returnUrl="@Url.Action("Index", "DocumentManagement", new { area = "Admin" })" , asp-area="Admin" asp-controller="DocumentManagement" asp-route-source="admin" asp-action="SoftDelete" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@doc.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        Delete
                                    </button>
                                </form>
                            } else
                            {
                                <form asp-area="Document" asp-controller="Document" asp-action="SoftDelete" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@doc.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        Delete
                                    </button>
                                </form>
                            }
                        } 
                        else
                        {
                            <form asp-action="UndeleteDocument" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@doc.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">
                                    Undelete 
                                </button>
                            </form>
                        }
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

 
<script src="~/js/DocumentAlerts.js"></script>