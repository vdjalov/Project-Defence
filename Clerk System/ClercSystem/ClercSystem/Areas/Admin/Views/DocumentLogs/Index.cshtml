@using ClercSystem.Areas.Admin.ViewModels.DocumentLogs;
@model IEnumerable<AllDocumentLogsViewModel>;


@if (TempData["Message"] != null)
{
    <div class="alert alert-danger">
        @TempData["Message"]
    </div>
}

<h2>Document Logs</h2>
   
<form method="get" asp-action="Index" class="mb-4">
    <div class="input-group">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="Search by document name, creator etc...." />
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i> Search
        </button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Clear</a>
    </div>
</form>

@if(User.IsInRole("Admin"))
{
<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th scope="col">Name</th>
            <th scope="col">Version</th>
            <th scope="col">Creator</th>
            <th scope="col">Creation Date</th>
            <th scope="col">Amended Date</th>
            <th scope="col">Description</th>
            <th scope="col">Actions</th>
            @*  <th scope="col" class="text-center">Program</th> *@
        </tr>
    </thead>
    <tbody>
        @foreach (AllDocumentLogsViewModel docLog in Model)
        {
            <tr>
                <td>@docLog.DocumentName</td>
                <td>@docLog.VersionNumber</td>
                <td>@docLog.CreatedByName</td>
                <td>@docLog.CreatedOn</td>
                <td>@docLog.AmendedOn</td>
                <td>@docLog.Desription</td>

                <td class="text-center">
                    <a class="btn btn-info btn-sm me-2 show-more-btn" onclick="ShowMore(event, '@docLog.DocumentId')">
                        <i class="bi bi-calendar-plus"></i> More
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

    <!-- Modal -->
    <div class="modal fade" id="logModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Log Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="modalBody">
                    <!-- Content from AJAX goes here -->
                    <div class="text-center">
                        <div class="spinner-border" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>


}


@section Scripts{
    <script src="~/js/Logs.js" asp-append-version="true"></script>
}
  