@model IEnumerable<ClercSystem.Data.Models.DocumentLog>

<div class="table-responsive">
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Action</th>
                <th>User</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td>@log.CreatedOn.ToString()</td>
                    <td>@log.Desription</td>
                    <td>@log.CreatedBy.NormalizedEmail</td>
                </tr>
            }
        </tbody>
    </table>
</div>
