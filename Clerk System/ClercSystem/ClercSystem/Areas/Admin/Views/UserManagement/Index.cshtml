﻿@using ClercSystem.Areas.Admin.Models.UserManagement;
@model IEnumerable<UserViewModel>


<div class="container mt-5">
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Message"]
        </div>
    }
    <h1 class="text-center mb-4">User Management</h1>

    <table class="table table-bordered table-hover">
        <thead class="thead-light">
            <tr>
                <th>Email</th>
                <th>FirstName</th>
                <th>LastName</th>
                <th>IsManager</th>
                <th>DepartmentId</th>
                <th>Roles</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>@user.FirstName</td>
                    <td>@user.LastName</td>
                    <td>
                        <form method="post" asp-action="AssignManager" asp-controller="UserManagement" asp-area="Admin" class="d-inline">
                            <input type="hidden" name="userId" asp-for="@user.Id"/>
                            <select asp-for="@user.IsManager" name="IsManager" class="form-select d-inline w-auto">
                                <option value="true">Yes</option>
                                <option value="false">No</option>
                            </select>
                            <button type="submit" class="btn btn-primary btn-sm">Assign Manager</button>
                        </form>
                    </td>
                    <td>Department</td>
                    <td>
                        @foreach (var role in user.Roles)
                        {
                            <span class="badge bg-secondary">@role</span>
                        }
                    </td>
                    <td>
                        <form method="post" asp-action="AssignRole" asp-controller="UserManagement" asp-area="Admin" class="d-inline">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <select name="role" class="form-select d-inline w-auto">
                                <option value="Admin">Admin</option>
                                <option value="User">User</option>
                                <option value="Observer">Observer</option>
                            </select>
                            <button type="submit" class="btn btn-primary btn-sm">Assign Role</button>
                        </form>

                        <form method="post" asp-action="RemoveRole" asp-controller="UserManagement" asp-area="Admin" class="d-inline ms-2">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <select name="role" class="form-select d-inline w-auto">
                                @foreach (var role in user.Roles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-warning btn-sm">Remove Role</button>
                        </form>

                        <form method="post" asp-action="DeleteUser" asp-controller="UserManagement" asp-area="Admin" class="d-inline ms-2">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">Delete User</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>