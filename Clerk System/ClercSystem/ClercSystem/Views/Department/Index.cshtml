@using ClercSystem.ViewModels.Department;
@model IEnumerable<AllDepartmentsViewModel>;

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

 <h2>Departments</h2> 
   
 @if (User.IsInRole("Admin"))
{
    <div class="d-flex justify-content-end mb-4">
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle"></i> Add New Department
        </a>
    </div>
}

<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th scope="col">Name</th>
            <th scope="col">Location</th>
            <th scope="col" class="text-center">Actions</th> 
        </tr>
    </thead>
    <tbody>
        @foreach (AllDepartmentsViewModel department in Model)
        {
            <tr>
                <td>@department.Name</td>
                <td>@department.Location</td>
                <td class="text-center">
                    <a asp-action="More" asp-route-id="@department.DepartmentId" class="btn btn-info btn-sm me-2">
                        <i class="bi bi-calendar-plus"></i> More
                    </a>
                    @if (User.IsInRole("Admin") || User.IsInRole("User"))
                    {
                        <a asp-action="Edit" asp-route-id="@department.DepartmentId" class="btn btn-info btn-sm me-2">
                            <i class="bi bi-calendar-plus"></i> Edit
                        </a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@department.DepartmentId" class="btn btn-info btn-sm me-2">
                            <i class="bi bi-calendar-plus"></i> Delete
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>