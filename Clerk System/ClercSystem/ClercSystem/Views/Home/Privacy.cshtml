@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container my-5">  @* privacy page design from bootsrap *@
    <div class="row">
        
       
        <nav class="col-md-3 mb-4">
            <div class="list-group sticky-top">
                <a href="#intro" class="list-group-item list-group-item-action">Introduction</a>
                <a href="#data" class="list-group-item list-group-item-action">Data We Collect</a>
                <a href="#use" class="list-group-item list-group-item-action">How We Use Data</a>
                <a href="#cookies" class="list-group-item list-group-item-action">Cookies</a>
                <a href="#rights" class="list-group-item list-group-item-action">Your Rights</a>
                <a href="#contact" class="list-group-item list-group-item-action">Contact</a>
            </div>
        </nav>

    
        <div class="col-md-9">
            
            <h1 class="mb-4">Privacy Policy</h1>
            <p class="text-muted">Last updated: @DateTime.Now.ToShortDateString()</p>

            <section id="intro" class="mb-5">
                <h3>Introduction</h3>
                <p>
                    We respect your privacy and are committed to protecting your personal data in accordance with GDPR.
                </p>
            </section>

            <section id="data" class="mb-5">
                <h3>Data We Collect</h3>
                <ul>
                    <li>Personal identification (name, email)</li>
                    <li>Usage data (IP address, browser type)</li>
                    <li>Cookies and tracking data</li>
                </ul>
            </section>

            <section id="use" class="mb-5">
                <h3>How We Use Your Data</h3>
                <p>
                    We use your data to provide and improve our services, communicate with you, and comply with legal obligations.
                </p>
            </section>

            <section id="cookies" class="mb-5">
                <h3>Cookies</h3>
                <p>
                    We use cookies to enhance your experience. You can control cookies through your browser settings.
                </p>
            </section>

            <section id="rights" class="mb-5">
                <h3>Your Rights (GDPR)</h3>
                <ul>
                    <li>Right to access your data</li>
                    <li>Right to rectification</li>
                    <li>Right to erasure ("right to be forgotten")</li>
                    <li>Right to restrict processing</li>
                    <li>Right to data portability</li>
                </ul>
            </section>

            <section id="contact" class="mb-5">
                <h3>Contact Us</h3>
                <p>
                    If you have any questions about this Privacy Policy, contact us at:
                    <br />
                    <strong>Email:</strong> support@softuni.net
                </p>
            </section>

        </div>
    </div>
</div>