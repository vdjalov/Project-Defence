@using ClercSystem.ViewModels.Category;
@model CreateCategoryViewModel;

<h2>Add a Category</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="CategoryName" class="control-label"></label>
        <input asp-for="CategoryName" class="form-control" />
        <span asp-validation-for="CategoryName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description" class="control-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <button type="submit" class="btn btn-primary">Add Categories</button>
        <a asp-action="Index" class="btn btn-secondary ml-2">Back to List Of Categories</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}