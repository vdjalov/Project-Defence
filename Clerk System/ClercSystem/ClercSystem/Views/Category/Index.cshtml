<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th scope="col">Name</th>
            <th scope="col">Actions</th>
            @*  <th scope="col" class="text-center">Program</th> *@
        </tr>
    </thead>
    <tbody>
        @foreach (AllCategoriesViewModel category in Model)
        {
            <tr>
                <td>@category.CategoryName</td>
                @* <td>@department.Location</td> *@
                <td class="text-center">
                    <a asp-action="more" asp-route-id="@category.Id" class="btn btn-info btn-sm me-2">
                        <i class="bi bi-calendar-plus"></i> More
                    </a>
                    <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-info btn-sm me-2">
                        <i class="bi bi-calendar-plus"></i> Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-info btn-sm me-2">
                        <i class="bi bi-calendar-plus"></i> Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>