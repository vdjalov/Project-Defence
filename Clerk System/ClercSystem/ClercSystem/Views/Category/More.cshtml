@using ClercSystem.ViewModels.Category;
@model CategoryMoreViewModel;

@{
    ViewData["Title"] = "Details";
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-danger">
        @TempData["Message"]
    </div>
}

<h2>DETAILS</h2>

<p><strong>Title:</strong> @Model.CategoryName</p>
<p><strong>File Path:</strong> @Model.Description</p>


<a asp-action="Index" class="btn btn-primary">Back to All Categories</a>
