@using ClercSystem.ViewModels.Document;
@model IEnumerable<AllDocumentsViewModel>;

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

