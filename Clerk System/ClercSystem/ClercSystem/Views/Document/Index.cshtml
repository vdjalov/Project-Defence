@using ClercSystem.ViewModels.Document;
@model IEnumerable<AllDocumentsViewModel>;

@{
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-danger temp-alert">
        @TempData["Message"]
    </div>
}


<h2>Documents</h2> 
<form method="get" asp-action="Index" class="mb-4">
    <div class="input-group">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="Search by name, creator, category, department..." />
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i> Search
        </button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Clear</a>
    </div>
</form>
@if (User.IsInRole("Admin") || User.IsInRole("User"))
{
    <div class="d-flex justify-content-end mb-4">
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle"></i> Add New Document
        </a>
    </div>
}

<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th scope="col">Name</th>
            <th scope="col">Creator</th>
            <th scope="col">Category</th>
            <th scope="col">Department</th>
            <th scope="col" class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (AllDocumentsViewModel doc in Model)
        {
            <tr>
                <td>@doc.Title</td>
                <td>@doc.Createdby</td>
                <td>@doc.CategoryName</td>
                <td>@doc.DepartmentName</td>
                <td class="text-center">
                    <a asp-action="More" asp-route-id="@doc.Id" class="btn btn-info btn-sm me-2">
                        <i class="bi bi-calendar-plus"></i> More
                    </a>

                    @if (User.IsInRole("Admin") || User.IsInRole("User"))
                    {
                        <a asp-action="Edit" asp-route-id="@doc.Id" class="btn btn-info btn-sm me-2">
                            <i class="bi bi-calendar-plus"></i> Edit
                        </a>
                        <a asp-action="SoftDelete" asp-route-id="@doc.Id" class="btn btn-info btn-sm me-2">
                            <i class="bi bi-calendar-plus"></i> Delete
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@* PAGINATION BOOTSRAP *@
<nav aria-label="Documents pagination">
    <ul class="pagination pagination-lg justify-content-center">

        <!-- Previous -->
        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
            <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(currentPage - 1)"
                   asp-route-search="@ViewBag.Search">
                <i class="bi bi-chevron-left">previous</i>
            </a>
        </li>

        <!-- First page (optional) -->
        @if (currentPage > 2)
        {
            <li class="page-item">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="1"
                       asp-route-search="@ViewBag.Search">
                    1
                </a>
            </li>

            <li class="page-item disabled">
                <span class="page-link">....</span>
            </li>
        }

        <!-- Pages around current -->
        @for (int i = Math.Max(1, currentPage - 1); i <= Math.Min(totalPages, currentPage + 1); i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search">
                    @i
                </a>
            </li>
        }

        <!-- Last page (optional) -->
        @if (currentPage < totalPages - 1)
        {
            <li class="page-item disabled">
                <span class="page-link">...</span>
            </li>

            <li class="page-item">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@totalPages"
                       asp-route-search="@ViewBag.Search">
                    @totalPages
                </a>
            </li>
        }

        <!-- Next -->
        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
            <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(currentPage + 1)"
                   asp-route-search="@ViewBag.Search">
                <i class="bi bi-chevron-right">next</i>
            </a>
        </li>

    </ul>
</nav>

<script src="~/js/alerts.js"></script>