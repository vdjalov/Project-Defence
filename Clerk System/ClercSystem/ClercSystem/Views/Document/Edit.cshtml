@using ClercSystem.ViewModels.Document;
@model EditDocumentViewModel;

@if (User.IsInRole("Admin") || User.IsInRole("User"))
{
    
<h2>Edit Document</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-danger temp-alert">
        @TempData["Message"]
    </div>
}

    <form asp-action="Edit" method="post">
        <input asp-for="CreatedById" type="hidden" value="@Model.CreatedById"/>
        <div class="form-group">
            <label asp-for="Title" class="control-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="FilePath" class="control-label"></label>
            <input asp-for="FilePath" class="form-control" />
            <span asp-validation-for="FilePath" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="TimeToAnswer" class="control-labe" ></label>
            <input asp-for="TimeToAnswer" class="form-control" type="datetime" />
            <span asp-validation-for="TimeToAnswer" class="text-danger"></span>
        </div>
    
        <div class="form-group">
            <label asp-for="Description" class="control-label"></label>
            <textarea asp-for="Description" class="form-control"> </textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="HasBeenAnswered" class="control-label"></label>
            <select asp-for="HasBeenAnswered" class="form-select">
                <option value="true">Yes</option>
                <option value="false">No</option>
            </select>
        </div>

        <div class="form-group">
            <label asp-for="DepartmentId" class="control-label">Department</label>
            <select asp-for="DepartmentId" class="form-select">
                @foreach (var department in Model.Departments)
                {
                    <option value="@department.DepartmentId">@department.Name</option>
                
                }
            </select>
        </div>

        <div class="form-group">
            <label asp-for="CategoryId" class="control-label">Category</label>
            <select asp-for="CategoryId" class="form-select">
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id">@category.CategoryName</option>
                }
            </select>
        </div>

                @if(ViewBag.UserId == ViewBag.CreatorId && User.IsInRole("Admin"))
            {
            <div class="form-group">
                <label asp-for="PermissionType" class="control-label">Permissions</label>
                <select asp-for="PermissionType" class="form-select">
                    <option value="Read">Read</option>
                    <option value="Write">Write</option>
                    <option value="Full">Full</option>
                </select>
            </div>
            } else
            {
                // returns default value if user not admin so that it does not return null
                <input asp-for="PermissionType" type="hidden" value="@Model.PermissionType" />     
            }

        

        <div class="form-group mt-3">
            <button type="submit" class="btn btn-primary">Edit Document</button>
            <a asp-action="Index" class="btn btn-secondary ml-2">Back to List Of Documents</a>
        </div>


    </form>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }


}